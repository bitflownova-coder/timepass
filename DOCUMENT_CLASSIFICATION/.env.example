# SmartDoc AI Environment Configuration
# Copy this file to .env and update with your values
# NEVER commit .env file to version control

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

# Environment: development, testing, production
FLASK_ENV=development

# Application debug mode (ALWAYS False in production)
DEBUG=False

# Secret key for session management (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-very-secure-random-key-here-change-this

# Application name
APP_NAME=SmartDoc AI


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (Development)
# DATABASE_URL=sqlite:///app.db

# PostgreSQL (Production) - Recommended for production
DATABASE_URL=postgresql://smartdoc:your_password@localhost:5432/smartdoc_db

# SQLAlchemy tracking modifications (disable for production)
SQLALCHEMY_TRACK_MODIFICATIONS=False


# ============================================================================
# JWT AUTHENTICATION
# ============================================================================

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=your-jwt-secret-key-here

# JWT token expiration in seconds (86400 = 24 hours)
JWT_ACCESS_TOKEN_EXPIRES=86400

# JWT refresh token expiration in seconds (2592000 = 30 days)
JWT_REFRESH_TOKEN_EXPIRES=2592000


# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Maximum file upload size in bytes (52428800 = 50MB)
MAX_CONTENT_LENGTH=52428800

# Upload folder path
UPLOAD_FOLDER=data/uploads

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=pdf,docx,doc,jpg,jpeg,png

# Allowed MIME types (comma-separated)
ALLOWED_MIMETYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png


# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Encryption key for AES-256 encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-encryption-key-here

# Password hashing rounds (higher = more secure but slower)
BCRYPT_LOG_ROUNDS=12

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com

# Rate limit: requests per hour
RATE_LIMIT_PER_HOUR=1000

# Session cookie settings
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict

# SSL certs (optional; enables HTTPS in run.py)
SSL_CERT_PATH=
SSL_KEY_PATH=


# ============================================================================
# OCR CONFIGURATION
# ============================================================================

# Tesseract OCR path
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux: /usr/bin/tesseract
# macOS: /usr/local/bin/tesseract
TESSERACT_PATH=/usr/bin/tesseract

# Enable OCR processing
ENABLE_OCR=True

# OCR timeout in seconds
OCR_TIMEOUT=30


# ============================================================================
# MACHINE LEARNING CONFIGURATION
# ============================================================================

# Model folder path
MODEL_FOLDER=models

# TF-IDF vectorizer pickle file
TFIDF_MODEL_PATH=models/tfidf_vectorizer.pkl

# Classification model pickle file
CLASSIFIER_MODEL_PATH=models/logistic_model.pkl

# Confidence threshold for auto-suggestion (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.80

# Confidence threshold for asking user (0.0 to 1.0)
MEDIUM_CONFIDENCE_THRESHOLD=0.60

# Cosine similarity threshold for folder matching
COSINE_SIMILARITY_THRESHOLD=0.70

# Training data folder path
TRAINING_DATA_FOLDER=data/training


# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================

# Email server settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Sender email address
MAIL_DEFAULT_SENDER=noreply@smartdoc-ai.com


# ============================================================================
# REDIS CONFIGURATION (Optional - for caching/sessions)
# ============================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Redis password (if required)
REDIS_PASSWORD=


# ============================================================================
# AWS S3 CONFIGURATION (Optional - for cloud file storage)
# ============================================================================

# Use S3 for file storage (True/False)
USE_S3_STORAGE=False

# AWS credentials
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# S3 bucket name
AWS_S3_BUCKET=smartdoc-uploads

# AWS region
AWS_REGION=us-east-1


# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# Audit log file path
AUDIT_LOG_FILE=logs/audit.log

# Maximum log file size in MB
LOG_MAX_SIZE=10

# Number of backup log files to keep
LOG_BACKUP_COUNT=10

# ============================================================================
# MONITORING (SENTRY)
# ============================================================================

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================

BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=7
BACKUP_INCLUDE_LOGS=false


# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Default storage limit per user in bytes (5GB = 5368709120)
# ============================================================================
# FILE MONITORING (Watchdog)
# ============================================================================

# Semicolon-separated directories to watch
WATCH_DIRS=

# Optional explicit API base (default http://localhost:5000)
WATCH_API=http://localhost:5000

# Auth for watcher uploads (use either token OR email/password)
WATCH_TOKEN=
WATCH_EMAIL=
WATCH_PASSWORD=

# Comma-separated extensions
WATCH_EXTS=pdf,docx,doc,txt,jpg,jpeg,png,gif,bmp,webp
DEFAULT_STORAGE_LIMIT=5368709120

# Permanent session lifetime in seconds (3600 = 1 hour)
PERMANENT_SESSION_LIFETIME=3600

# Duplicate detection enabled
ENABLE_DUPLICATE_DETECTION=True

# Auto-classify documents
AUTO_CLASSIFY=True

# Enable user feedback collection
ENABLE_FEEDBACK=True

# Number of documents to show per page
ITEMS_PER_PAGE=20


# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================

# Backup folder path
BACKUP_FOLDER=/home/smartdoc/backups

# Backup frequency in hours
BACKUP_FREQUENCY=24

# Number of backups to keep
BACKUP_COUNT=30


# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================

# Admin email for notifications
ADMIN_EMAIL=admin@yourdomain.com

# Enable admin panel
ENABLE_ADMIN_PANEL=True


# ============================================================================
# DEVELOPMENT SETTINGS (Only for development)
# ============================================================================

# Enable hot reloading
FLASK_DEBUG=True

# Enable auto-reloading on code changes
FLASK_RELOAD=True

# Testing mode
TESTING=False

# Database for testing
TEST_DATABASE_URL=sqlite:///test.db


# ============================================================================
# DOCKER / DEPLOYMENT SETTINGS
# ============================================================================

# Gunicorn workers (recommended: 2 * CPU_cores + 1)
GUNICORN_WORKERS=4

# Gunicorn timeout in seconds
GUNICORN_TIMEOUT=120

# Port to bind the application
PORT=5000

# Nginx SSL certificate paths (used in docker-compose + nginx.conf)
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# Health check endpoint (used by Docker)
HEALTH_CHECK_ENDPOINT=/health


# ============================================================================
# PRODUCTION SETTINGS (Only for production)
# ============================================================================

# Production domain
PRODUCTION_DOMAIN=yourdomain.com

# Production URL
PRODUCTION_URL=https://yourdomain.com

# Analytics tracking (optional)
ANALYTICS_ENABLED=False
ANALYTICS_TOKEN=

# Sentry error tracking (optional)
SENTRY_DSN=
